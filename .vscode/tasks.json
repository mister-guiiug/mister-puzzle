{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build: Server",
      "type": "shell",
      "command": "tsc",
      "args": ["--project", "tsconfig.json"],
      "options": {
        "cwd": "${workspaceFolder}/puzzle-tracker/server"
      },
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "Start: Client Dev",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}/puzzle-tracker/client"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:"
        }
      }
    }
  ]
}
