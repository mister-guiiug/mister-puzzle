{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173/mister-puzzle/",
      "webRoot": "${workspaceFolder}/src",
      "sourceMapPathOverrides": {
        "/mister-puzzle/*": "${webRoot}/*"
      },
      "preLaunchTask": "Dev: Vite"
    },
    {
      "name": "Debug: Edge",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:5173/mister-puzzle/",
      "webRoot": "${workspaceFolder}/src",
      "sourceMapPathOverrides": {
        "/mister-puzzle/*": "${webRoot}/*"
      },
      "preLaunchTask": "Dev: Vite"
    }
  ]
}
