{
  "rules": {
    "puzzles": {
      ".indexOn": ["isPublic"],
      ".read": true,
      "$roomCode": {
        ".read": true,
        ".write": "!data.exists() || newData.val() === null",

        "isPublic": {
          ".write": "data.parent().exists()",
          ".validate": "newData.isBoolean()"
        },

        "passwordHash": {
          ".write": "data.parent().exists()",
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length > 0)"
        },

        "createdBy": {
          ".write": "!data.exists()",
          ".validate": "newData.isString() && newData.val().length < 100"
        },

        "rows": {
          ".write": "data.parent().exists()",
          ".validate": "newData.isNumber() && newData.val() > 0"
        },

        "cols": {
          ".write": "data.parent().exists()",
          ".validate": "newData.isNumber() && newData.val() > 0"
        },

        "totalPieces": {
          ".write": "data.parent().exists()",
          ".validate": "newData.isNumber() && newData.val() > 0"
        },

        "placedPieces": {
          ".write": "data.parent().exists()",
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= newData.parent().child('totalPieces').val()"
        },

        "checkpoints": {
          "$checkpointId": {
            ".write": "data.parent().parent().exists()",
            "completed": {
              ".validate": "newData.isBoolean()"
            },
            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length < 100"
            },
            "id": {
              ".validate": "newData.isString()"
            },
            "createdBy": {
              ".validate": "newData.isString() && newData.val().length < 100"
            }
          }
        },

        "history": {
          "$entry": {
            ".write": "data.parent().parent().exists()",
            ".validate": "newData.hasChildren(['timestamp', 'placedPieces']) && newData.child('timestamp').isNumber() && newData.child('placedPieces').isNumber()"
          }
        },

        "photos": {
          "$photoId": {
            ".write": "data.parent().parent().exists()",
            ".validate": "newData.isString() && newData.val().length < 2000000"
          }
        },

        "members": {
          "$sessionId": {
            ".write": "data.parent().parent().exists()",
            ".validate": "!newData.exists() || (newData.hasChildren(['pseudo', 'lastSeen']) && newData.child('pseudo').isString() && newData.child('lastSeen').isNumber())"
          }
        }
      }
    }
  }
}
