{
  "rules": {
    "puzzles": {
      ".indexOn": ["isPublic"],
      ".read": true,
      "$roomCode": {
        ".read": true,
        ".write": "!data.exists() || newData.val() === null",

        "isPublic": {
          ".write": "data.parent().exists()",
          ".validate": "newData.isBoolean()"
        },

        "passwordHash": {
          ".write": "data.parent().exists()",
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length > 0 && newData.val().length <= 128)"
        },

        "createdBy": {
          ".write": "!data.exists()",
          ".validate": "newData.isString() && newData.val().length < 100"
        },

        "schemaVersion": {
          ".write": "!data.exists()",
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 99"
        },

        "name": {
          ".write": "data.parent().exists()",
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length < 200"
        },

        "rows": {
          ".write": "data.parent().exists()",
          ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() <= 5000"
        },

        "cols": {
          ".write": "data.parent().exists()",
          ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() <= 5000"
        },

        "totalPieces": {
          ".write": "data.parent().exists()",
          ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() <= 25000000"
        },

        "placedPieces": {
          ".write": "data.parent().exists()",
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= newData.parent().child('totalPieces').val()"
        },

        "checkpoints": {
          "$checkpointId": {
            ".write": "data.parent().parent().exists()",
            ".validate": "!newData.exists() || (newData.hasChildren(['id', 'name', 'completed']) && newData.child('id').isString() && newData.child('name').isString() && newData.child('name').val().length > 0 && newData.child('name').val().length < 100 && newData.child('completed').isBoolean())",
            "completed": {
              ".validate": "newData.isBoolean()"
            },
            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length < 100"
            },
            "id": {
              ".validate": "newData.isString()"
            },
            "createdBy": {
              ".validate": "newData.isString() && newData.val().length < 100"
            }
          }
        },

        "history": {
          "$entry": {
            ".write": "data.parent().parent().exists()",
            ".validate": "newData.hasChildren(['timestamp', 'placedPieces']) && newData.child('timestamp').isNumber() && newData.child('placedPieces').isNumber() && (!newData.child('pseudo').exists() || (newData.child('pseudo').isString() && newData.child('pseudo').val().length < 100))"
          }
        },

        "photos": {
          "$photoId": {
            ".write": "data.parent().parent().exists()",
            ".validate": "!newData.exists() || (newData.child('data').isString() && newData.child('data').val().length < 2000000 && newData.child('rotation').isNumber() && (!newData.child('caption').exists() || (newData.child('caption').isString() && newData.child('caption').val().length < 500)) && (!newData.child('addedAt').exists() || newData.child('addedAt').isNumber()) && (!newData.child('sortOrder').exists() || newData.child('sortOrder').isNumber()))"
          }
        },

        "members": {
          "$sessionId": {
            ".write": "data.parent().parent().exists()",
            ".validate": "!newData.exists() || (newData.hasChildren(['pseudo', 'lastSeen']) && newData.child('pseudo').isString() && newData.child('lastSeen').isNumber())"
          }
        }
      }
    }
  }
}
