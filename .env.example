# Firebase project configuration
# Copy this file to .env.local and fill in your values from:
# Firebase Console > Project Settings > Your apps > SDK setup and configuration

# Optionnel : origine du site déployé (sans slash final), pour canonical, Open Graph, sitemap, robots, llms.txt
# Ex. GitHub Pages : https://votre-compte.github.io
# Si absent, le build utilise une valeur par défaut définie dans vite-plugin-seo.ts
# VITE_PUBLIC_SITE_ORIGIN=

# Optionnel : Google Tag Manager (conteneur web). Format : GTM-XXXXXXX
# VITE_GTM_CONTAINER_ID=
# Optionnel : Google Analytics 4 seul (sans GTM). Format : G-XXXXXXXXXX
# Si GTM et GA4 sont tous deux définis, seul GTM est injecté : configurez GA4 dans l’interface GTM.
# VITE_GA_MEASUREMENT_ID=

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optionnel : endpoint HTTPS qui reçoit en POST le JSON { scope, message, ctx, ts, href } (CORS doit autoriser l’origine du site)
# VITE_ERROR_INGEST_URL=

# Serveur optionnel (dossier server/, Socket.io) : liste d’origines CORS séparées par des virgules. Laisser vide = toutes les origines.
# CORS_ORIGINS=http://localhost:5173,https://votre-compte.github.io
